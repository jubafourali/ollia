{
  "expo": {
    "name": "Ollia",
    "slug": "ollia",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ollia",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F0E2C4",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#F0E2C4",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ollia.app",
      "associatedDomains": [
        "applinks:ollia.app"
      ],
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification",
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F0E2C4"
      },
      "package": "com.ollia.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "ollia.app",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://ollia.app"
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f8caa16a-73ff-4a97-bf1e-00f2350f09ed"
      }
    },
    "owner": "jubafourali"
  }
}
