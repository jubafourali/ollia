{
  "expo": {
    "name": "Ollia",
    "slug": "ollia",
    "version": "1.1.22",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ollia",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F0E2C4",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#F0E2C4",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ollia.app",
      "associatedDomains": [
        "applinks:ollia.app"
      ],
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification",
          "location"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationAlwaysUsageDescription": "Ollia uses background location changes only as an activity trigger to let your family know you're okay. No location data is stored or shared.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Ollia uses background location changes only as an activity trigger to let your family know you're okay. No location data is stored or shared.",
        "NSLocationWhenInUseUsageDescription": "Ollia uses location changes only as an activity trigger. No location data is stored or shared."
      },
      "appleTeamId": "CP67H3M7M2"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F0E2C4"
      },
      "package": "com.ollia.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "ollia.app",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "ollia.app",
              "pathPrefix": "/premium-success"
            },
            {
              "scheme": "https",
              "host": "ollia.app",
              "pathPrefix": "/premium-cancel"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://ollia.app",
          "root": "src/app"
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Ollia uses background location changes only as an activity trigger to let your family know you're okay. No location data is stored or shared.",
          "locationWhenInUsePermission": "Ollia uses location changes only as an activity trigger. No location data is stored or shared.",
          "isIosBackgroundLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f8caa16a-73ff-4a97-bf1e-00f2350f09ed"
      }
    },
    "owner": "jubafourali"
  }
}
